# ==========================================
# PostgreSQL
# ==========================================
POSTGRES_USER=devblog_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# ==========================================
# JWT Configuration
# ==========================================
# Shared between NAuth and NNews (minimum 64 characters)
JWT_SECRET=your_jwt_secret_key_here_at_least_64_characters_long_change_this

# ==========================================
# SSL Certificate
# ==========================================
CERTIFICATE_PASSWORD=your_certificate_password_here
CERTIFICATE_PATH=/app/certs/certificate.pfx

# ==========================================
# zTools API
# ==========================================
ZTOOLS_PORT=5001
CHATGPT_APIKEY=your_openai_api_key_here
CHATGPT_APIURL=https://api.openai.com/v1/chat/completions
CHATGPT_MODEL=gpt-4
CHATGPT_IMAGEAPIURL=https://api.openai.com/v1/images/generations
MAILERSEND__MAILSENDER=your_sender_email_here
MAILERSEND__APIURL=https://api.mailersend.com/v1
MAILERSEND__APITOKEN=your_mailersend_token_here
S3__ACCESSKEY=your_s3_access_key_here
S3__SECRETKEY=your_s3_secret_key_here
S3__ENDPOINT=your_s3_endpoint_here

# ==========================================
# NAuth API Ports
# ==========================================
NAUTH_HTTP_PORT=5004
NAUTH_HTTPS_PORT=5005

# ==========================================
# NNews API Ports
# ==========================================
NNEWS_HTTP_PORT=5007
NNEWS_HTTPS_PORT=5008

# ==========================================
# Frontend
# ==========================================
FRONTEND_PORT=3000
VITE_AUTH_API_URL=http://localhost:5004
VITE_NEWS_API_URL=http://localhost:5007
